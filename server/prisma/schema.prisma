  dataBase64 String?  @map("data_base64") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  request AgentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("agent_attachments")
}

model WorkflowDefinition {
  id             String             @id @default(uuid())
  agentRequestId String             @unique @map("agent_request_id")
  name           String
  objective      String             @db.Text
  triggerEvent   String?            @map("trigger_event") @db.Text
  outputType     WorkflowOutputType @map("output_type")
  graphNotes     Json?              @map("graph_notes")
  createdAt      DateTime           @default(now()) @map("created_at")

  request      AgentRequest         @relation(fields: [agentRequestId], references: [id], onDelete: Cascade)
  states       WorkflowState[]
  transitions  WorkflowTransition[]

  @@map("workflow_definitions")
}

model WorkflowState {
  id           String   @id @default(uuid())
  definitionId String   @map("definition_id")
  stateKey     String   @map("state_key")
  label        String
  sortOrder    Int      @default(0) @map("sort_order")

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, stateKey], map: "workflow_state_key_unique")
  @@index([definitionId])
  @@map("workflow_states")
}

model WorkflowTransition {
  id           String   @id @default(uuid())
  definitionId String   @map("definition_id")
  fromStateKey String   @map("from_state_key")
  toStateKey   String   @map("to_state_key")
  label        String?
  rolesJson    Json?    @map("roles_json")

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("workflow_transitions")
}

model AgentRunLog {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  actorType String   @default("USER") @map("actor_type")
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  request AgentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  packagesAsPlanSource     ExecutionPackage[] @relation("SourcePlanRunLog")
  packagesAsWorkflowSource ExecutionPackage[] @relation("SourceWorkflowRunLog")
  packagesAsSchemaSource   ExecutionPackage[] @relation("SourceSchemaRunLog")

  @@index([requestId])
  @@map("agent_run_logs")
}

model AgentAuditEvent {
  id          String   @id @default(uuid())
  requestId   String   @map("request_id")
  userId      String?  @map("user_id")
  action      String
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  createdAt   DateTime @default(now()) @map("created_at")

  request AgentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([createdAt])
  @@map("agent_audit_events")
}

// --- Multi-tenant org shell (used by QMS Agent execution packaging) ---

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  /// Clerk Organization id (org_…) — links this row to the SSO tenant.
  clerkOrgId  String?  @unique @map("clerk_org_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships         OrganizationMembership[]
  executionPackages   ExecutionPackage[]
  documents           Document[]
  cmmcDocuments       CmmcDocument[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  packagesCreated   ExecutionPackage[] @relation("ExecutionPackageCreator")
  packagesAssigned  ExecutionPackage[] @relation("ExecutionPackageAssignee")

  @@unique([organizationId, userId], map: "organization_membership_unique")
  @@index([userId])
  @@map("organization_memberships")
}

enum ExecutionPackageType {
  UI_CHANGE
  WORKFLOW_BUILD
  SCHEMA_CHANGE
  MIXED
}

enum ExecutionPackageStatus {
  DRAFT
  READY
  SENT_TO_DEV
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExecutionTaskType {
  FRONTEND
  BACKEND
  DATABASE
  VALIDATION
  TESTING
  DOCS
}

enum ExecutionTaskStatus {
  OPEN
  BLOCKED
  IN_PROGRESS
  DONE
}

enum CursorHandoffStatus {
  DRAFT
  READY
  EXPORTED
  SENT
}

model ExecutionPackage {
  id                       String                  @id @default(uuid())
  organizationId           String                  @map("organization_id")
  agentRequestId           String                  @unique @map("agent_request_id")
  title                    String
  summary                  String                  @db.Text
  packageType              ExecutionPackageType    @map("package_type")
  status                   ExecutionPackageStatus  @default(DRAFT)
  sourcePlanRunLogId      String?                 @map("source_plan_run_log_id")
  sourceWorkflowRunLogId   String?                 @map("source_workflow_run_log_id")
  sourceSchemaRunLogId     String?                 @map("source_schema_run_log_id")
  payloadJson              Json                    @map("payload_json")
  checklistJson            Json                    @map("checklist_json")
  /** Module / template intelligence (read-only suggestions; overrides stored separately). */
  intelligenceJson         Json?                   @map("intelligence_json")
  inferredModuleKey        String?                 @map("inferred_module_key")
  moduleKeyOverride        String?                 @map("module_key_override")
  suggestedTemplateKey     String?                 @map("suggested_template_key")
  templateKeyOverride      String?                 @map("template_key_override")
  createdByMembershipId    String                  @map("created_by_membership_id")
  assignedToMembershipId   String?                 @map("assigned_to_membership_id")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  agentRequest             AgentRequest            @relation(fields: [agentRequestId], references: [id], onDelete: Restrict)
  createdByMembership      OrganizationMembership  @relation("ExecutionPackageCreator", fields: [createdByMembershipId], references: [id], onDelete: Restrict)
  assignedToMembership     OrganizationMembership? @relation("ExecutionPackageAssignee", fields: [assignedToMembershipId], references: [id], onDelete: SetNull)
  sourcePlanRunLog         AgentRunLog?            @relation("SourcePlanRunLog", fields: [sourcePlanRunLogId], references: [id], onDelete: SetNull)
  sourceWorkflowRunLog     AgentRunLog?            @relation("SourceWorkflowRunLog", fields: [sourceWorkflowRunLogId], references: [id], onDelete: SetNull)
  sourceSchemaRunLog       AgentRunLog?            @relation("SourceSchemaRunLog", fields: [sourceSchemaRunLogId], references: [id], onDelete: SetNull)
  tasks                    ExecutionTask[]
  cursorHandoffs           CursorHandoff[]

  @@index([organizationId])
  @@index([status])
  @@index([packageType])
  @@index([inferredModuleKey])
  @@index([suggestedTemplateKey])
  @@map("execution_packages")
}

model ExecutionTask {
  id                 String               @id @default(uuid())
  executionPackageId String               @map("execution_package_id")
  title              String
  description        String               @db.Text
  taskType           ExecutionTaskType    @map("task_type")
  status             ExecutionTaskStatus  @default(OPEN)
  orderIndex         Int                  @default(0) @map("order_index")
  metadataJson       Json?                @map("metadata_json")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  executionPackage ExecutionPackage @relation(fields: [executionPackageId], references: [id], onDelete: Cascade)

  @@index([executionPackageId])
  @@map("execution_tasks")
}

model CursorHandoff {
  id                  String              @id @default(uuid())
  executionPackageId  String              @map("execution_package_id")
  handoffPrompt       String              @map("handoff_prompt") @db.Text
  repoContextJson     Json                @map("repo_context_json")
  fileTargetsJson     Json                @map("file_targets_json")
  schemaContextJson   Json                @map("schema_context_json")
  workflowContextJson Json                @map("workflow_context_json")
  /** Full structured export (read-only artifact for engineering / Cursor). */
  exportPayloadJson   Json?               @map("export_payload_json")
  status              CursorHandoffStatus @default(DRAFT)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  executionPackage ExecutionPackage @relation(fields: [executionPackageId], references: [id], onDelete: Cascade)

  @@index([executionPackageId])
  @@map("cursor_handoffs")
}

// --- Codex ↔ QMS CMMC governance contract: control tagging junctions ---
// Read by GET /api/v1/cmmc/controls/{controlId}/documents and the bulk variant.
// One row = "this document covers this CMMC control." Tagging is operator-driven via the QMS admin UI.

model DocumentCmmcControlTag {
  documentId    String   @map("document_id")
  controlId     String   @map("control_id") // e.g. "3.1.4"
  coverageNote  String?  @map("coverage_note") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, controlId])
  @@index([controlId])
  @@map("document_cmmc_control_tags")
}

model CmmcDocumentControlTag {
  cmmcDocumentId String   @map("cmmc_document_id")
  controlId      String   @map("control_id")
  coverageNote   String?  @map("coverage_note") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  cmmcDocument   CmmcDocument @relation(fields: [cmmcDocumentId], references: [id], onDelete: Cascade)

  @@id([cmmcDocumentId, controlId])
  @@index([controlId])
  @@map("cmmc_document_control_tags")
}

// --- External submissions bridge (Codex SSP Doc Control, Phase 2) ---
// Inbound submissions from external systems (today: Codex). Each row is the
// staging record for an authorized record that QMS will then walk through its
// own Reviewer → Approver → Quality Release flow. The full inbound payload is
// preserved verbatim in payloadJson so a C3PAO can audit what the source
// system attested vs. what QMS released. The QMS Document is created in DRAFT
// inside the same transaction; once it reaches EFFECTIVE the manifest export
// picks it up and Codex Phase 3 links it back to this row by document_number
// + sha256 match.
//
// status is partially derived from the linked Document (see
// deriveSubmissionStatusFromDocument in src/lib/sspSubmissionContract.js) —
// REJECTED is the only persisted terminal that doesn't follow Document.status.

enum ExternalSubmissionStatus {
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  QUALITY_RELEASED
  REJECTED
}

model ExternalDocumentSubmission {
  id                       String   @id @default(uuid())
  externalSystem           String   @map("external_system") // e.g. "codex"
  inboundBridgeVersion     String   @default("1") @map("inbound_bridge_version")
  externalSubmissionId     String   @map("external_submission_id")
  externalOrganizationId   String   @map("external_organization_id")
  externalDocumentId       String   @map("external_document_id")
  externalVersionNumber    Int      @map("external_version_number")
  documentNumber           String   @map("document_number")
  documentType             DocumentType @map("document_type")
  payloadSha256            String   @map("payload_sha256")
  payloadJson              Json     @map("payload_json")
  pdfFileAssetId           String?  @unique @map("pdf_file_asset_id")
  controlsMapped           String[] @default([]) @map("controls_mapped")
  qmsDocumentId            String?  @unique @map("qms_document_id")
  status                   ExternalSubmissionStatus @default(PENDING_REVIEW)
  rejectedAt               DateTime? @map("rejected_at")
  rejectedById             String?   @map("rejected_by_id")
  rejectionReason          String?   @map("rejection_reason") @db.Text
  supersededBySubmissionId String?  @map("superseded_by_submission_id")
  submittedAt              DateTime @default(now()) @map("submitted_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  qmsDocument        Document?                    @relation(fields: [qmsDocumentId], references: [id], onDelete: SetNull)
  pdfFileAsset       FileAsset?                   @relation("ExternalSubmissionPdf", fields: [pdfFileAssetId], references: [id], onDelete: SetNull)
  rejectedBy         User?                        @relation("ExternalSubmissionRejector", fields: [rejectedById], references: [id], onDelete: SetNull)
  supersededBy       ExternalDocumentSubmission?  @relation("SubmissionSupersedes", fields: [supersededBySubmissionId], references: [id], onDelete: SetNull)
  supersedes         ExternalDocumentSubmission[] @relation("SubmissionSupersedes")

  // Idempotency: a repeat POST with the same (org, ext_doc, sha256) returns
  // the existing row with 200 OK rather than creating a duplicate.
  @@unique([externalOrganizationId, externalDocumentId, payloadSha256], map: "external_submission_idempotency")
  @@index([documentNumber])
  @@index([status])
  @@index([externalSystem, externalSubmissionId])
  @@map("external_document_submissions")
}
