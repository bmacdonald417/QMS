// ─────────────────────────────────────────────────────────────────────────────
// Trust Codex governance manifest ingest (JSON-only — hashes, not file uploads)
//
// QMS produces a signed mactech-governance-manifest.v1.1 envelope, ships it
// to codex via codexManifestClient.js, AND records the run here for QMS-
// internal audit/visibility. Two parallel audit trails: codex tracks what
// it received; QMS tracks what it produced. Both are append-only.
//
// GovernanceControlMapping (documentNumber → controlIds[]) is the LEGACY
// mapping seeded from scripts/governance-control-mapping.json. Going
// forward, document↔control mapping happens via the Phase 6 junction tables
// (DocumentCmmcControlTag, CmmcDocumentControlTag); this table remains as
// fallback for documents that haven't been tagged in the admin UI yet.
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// Determinate MacTech Vault Governance Package
//
// Canonical, IMMUTABLE roster of the documents every CMMC L2 vault carries.
// Every client gets the SAME document_number / document_type / controls_mapped
// set; only doc CONTENT is prefilled per-tenant (future questionnaire flow).
//
// One row per version. Once `is_active=true` and `published_at` is set, the
// row is read-only by application convention (no UPDATE/DELETE routes; the
// CLI script seedGovernancePackageVersion.js refuses to overwrite a
// published version). New versions are PUBLISHED — never mutated.
//
// CMMC alignment:
//   3.4.1 Baseline Configuration — frozen-blob snapshot of doc roster
//   3.4.2 Configuration Change Control — versioned via versionLabel
//   3.4.5 Authorize Changes — only published versions count as canonical
//   3.3.8 Audit Records Protection — published packages are read-only
//
// The frozen `manifestEnvelope` jsonb holds the full v1.2 envelope as it
// would be emitted at publish time: documents[] with sha256s, signatures,
// controls_touched, content_hash, etc. Storing the whole envelope means
// codex-side and QMS-side always see the same canonical set; the
// /system/governance-package UI just renders this blob.
// ─────────────────────────────────────────────────────────────────────────────
model GovernancePackageVersion {
  id              String   @id @default(uuid())
  versionLabel    String   @unique @map("version_label") // e.g. "v1.0.0"
  publishedAt     DateTime @map("published_at")
  publishedBy     String?  @map("published_by")
  contentHash     String   @map("content_hash") // sha256 of canonicalized envelope
  manifestEnvelope Json    @map("manifest_envelope")
  docCount        Int      @map("doc_count")
  controlsTouched String[] @map("controls_touched")
  isActive        Boolean  @default(false) @map("is_active") // exactly one true at a time
  notes           String?  @db.Text

  @@index([isActive])
  @@index([publishedAt])
  @@map("governance_package_versions")
}

model GovernanceControlMapping {
  id             String   @id @default(uuid())
  documentNumber String   @unique @map("document_number")
  controlIds     String[] @map("control_ids")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("governance_control_mapping")
}

model GovernanceManifestRun {
  id                    String   @id @default(uuid())
  runId                 String   @unique @map("run_id")
  manifestSchema        String?  @map("manifest_schema")
  generatedAt           DateTime @map("generated_at")
  generatedBy           String?  @map("generated_by")
  toolVersion           String?  @map("tool_version")
  basePath              String?  @map("base_path")
  documentsTotal        Int      @map("documents_total")
  governanceDocCount    Int      @map("governance_doc_count")
  supportingDocCount    Int      @map("supporting_doc_count")
  uniqueControlsCovered Int      @map("unique_controls_covered")
  reviewOverdue         Json     @map("review_overdue")
  ingestLog             Json?    @map("ingest_log")
  // v1.1 chain-of-custody fields (null on legacy v1 runs).
  contentHash           String?  @map("content_hash")
  signingHash           String?  @map("signing_hash")
  signatureKid          String?  @map("signature_kid")
  // Codex push outcome (null until/unless we attempt the push). Tracks
  // cross-system delivery for CMMC 3.3.4 alerting on missed manifests.
  codexPushedAt         DateTime? @map("codex_pushed_at")
  codexPushStatus       String?   @map("codex_push_status") // "stored" | "already_present" | "failed"
  codexPushError        String?   @map("codex_push_error")
  createdByUserId       String?  @map("created_by_user_id")
  createdAt             DateTime @default(now()) @map("created_at")

  createdBy      User?                    @relation("GovernanceManifestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  documentHashes GovernanceDocumentHash[]
  controlLinks   GovernanceControlLink[]

  @@index([createdAt])
  @@map("governance_manifest_runs")
}

model GovernanceDocumentHash {
  id                   String   @id @default(uuid())
  runId                String   @map("run_id")
  documentNumber       String   @map("document_number")
  documentName         String?  @map("document_name")
  documentType         String   @map("document_type")
  filePath             String?  @map("file_path")
  version              String?
  sha256               String
  fileSizeBytes        Int?     @map("file_size_bytes")
  effectiveDate        String?  @map("effective_date")
  nextReviewDate       String?  @map("next_review_date")
  status               String?
  inPlatformLibrary    Boolean  @default(false) @map("in_platform_library")
  controlsSource       String?  @map("controls_source") // "junctions" | "platform_mapping" | "manifest_fallback" | "none"
  controlsResolved     String[] @default([]) @map("controls_resolved")
  countsTowardCoverage Boolean  @default(true) @map("counts_toward_coverage")

  run GovernanceManifestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([documentNumber])
  @@map("governance_document_hashes")
}

model GovernanceControlLink {
