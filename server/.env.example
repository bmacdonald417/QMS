# Copy to .env and set values
# Use DATABASE_PUBLIC_URL when running locally or from outside Railway.
# Use DATABASE_URL when the API runs on Railway (same project as Postgres).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"
# Or from Railway: paste DATABASE_PUBLIC_URL for local/dev, DATABASE_URL for Railway deploy
JWT_SECRET="your-super-secret-key-change-in-production"
PORT=3001

# QMS Agent MCP read surface (GET /api/agent/mcp/open-requests). Must match X-Agent-Mcp-Secret header.
# AGENT_MCP_SECRET="generate-a-long-random-string"

# QMS Agent floating panel: conversational coach (POST /api/agent/assistant/chat). Optional; if unset, offline templates are used.
# OPENAI_API_KEY="sk-..."
# OPENAI_AGENT_MODEL="gpt-4o-mini"

# Integration token auth (replaces X-INTEGRATION-KEY)
# If missing, integration token auth is disabled with a startup warning
INTEGRATION_JWT_SECRET="separate-secret-for-integration-tokens"
INTEGRATION_TOKEN_TTL_MINUTES=10
# Temporary: allow legacy X-INTEGRATION-KEY when true (default false)
# ALLOW_LEGACY_INTEGRATION_KEY=false

# Canonical single-tenant org UUID. Server refuses to start without it.
# Obtain by running server/prisma/sql/20260505_phase1a_rename_org_to_mactech.sql
# against the target database; copy the returned id here. See server/prisma/sql/README
# (or the codex-cmmc rollout runbook) for the full migration sequence.
# TODO(multi-tenant): replace with per-request `org` JWT claim when a second tenant lands.
MACTECH_DEFAULT_ORG_ID="paste-uuid-from-phase1a-sql-here"
