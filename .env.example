# Production build-time values are committed in .env.production (public-safe:
# Clerk publishable key + canonical API URL). For LOCAL DEV, copy this file
# to .env.local and override as needed.
#
# In dev with npm run dev, the Vite proxy forwards /api to localhost:3001,
# so VITE_API_URL can be left unset.
# VITE_API_URL=http://localhost:3001
#
# Clerk publishable key for local dev. The pk_test_* key is the dev tenant's
# (clerk dashboard → API Keys); the production pk_live_* lives in
# .env.production. The sk_live_* secret is server-side only — never put it
# in any VITE_* variable, since those land in the browser bundle.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_…
