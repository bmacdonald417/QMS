# Dependencies
node_modules/

# Build artifacts — nixpacks doesn't carry the rebuilt dist into the runtime
# image, so we commit the bundled output. Always run `npm run build` with
# the production VITE_CLERK_PUBLISHABLE_KEY before committing or the
# placeholder will leak into prod.
*.local
*.tsbuildinfo

# Env
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/

# Cursor MCP (contains secrets; never commit)
.cursor/mcp.json

# OS
.DS_Store
Thumbs.db
