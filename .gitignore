# Dependencies
node_modules/

# Build artifacts — nixpacks doesn't carry the rebuilt dist into the runtime
# image, so we commit the bundled output. The VITE_* values needed by
# `npm run build` come from .env.production (committed; values are public-
# safe Clerk publishable + canonical API URL).
*.local
*.tsbuildinfo

# Env
.env
.env.*
!.env.example
!.env.production

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/

# Cursor MCP (contains secrets; never commit)
.cursor/mcp.json

# Claude Code working artifacts (briefs, screenshots, agent state)
.claude/

# OS
.DS_Store
Thumbs.db

# Generated governance manifests (local test / dev artifacts; not committed)
governance-manifest*.json

# Prisma migrate artifacts — QMS uses db push, not prisma migrate
server/prisma/migrations/
