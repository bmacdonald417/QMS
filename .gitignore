# Dependencies
node_modules/

# Build artifacts — Railway rebuilds via nixpacks `npm run build`, so the
# bundled JS lives only as a build output, never in git. Committing dist/
# leaks build-time env vars (e.g. VITE_CLERK_PUBLISHABLE_KEY) into the repo
# and lets stale local builds beat the freshly-built ones in production.
dist/
server/dist/
*.local
*.tsbuildinfo

# Env
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/

# Cursor MCP (contains secrets; never commit)
.cursor/mcp.json

# OS
.DS_Store
Thumbs.db
